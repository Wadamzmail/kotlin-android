From 31726352002706034f43e21d807774bd48d38511 Mon Sep 17 00:00:00 2001
From: Akash Yadav <contact@itsaky.com>
Date: Wed, 11 Mar 2026 16:44:52 +0530
Subject: [PATCH 3/8] fix: relocate javax.annotation in embeddable JARs

Classes from the javax.annotation package cause duplicate class errors in Android projects.

Signed-off-by: Akash Yadav <contact@itsaky.com>
---
 .../gradle-plugins-common/src/main/kotlin/embeddable.kt          | 1 +
 1 file changed, 1 insertion(+)

diff --git a/repo/gradle-build-conventions/gradle-plugins-common/src/main/kotlin/embeddable.kt b/repo/gradle-build-conventions/gradle-plugins-common/src/main/kotlin/embeddable.kt
index f10817407a8f..0abcce0c4fd2 100644
--- a/repo/gradle-build-conventions/gradle-plugins-common/src/main/kotlin/embeddable.kt
+++ b/repo/gradle-build-conventions/gradle-plugins-common/src/main/kotlin/embeddable.kt
@@ -25,6 +25,7 @@ val packagesToRelocate =
         "net.jpountz",
         "one.util.streamex",
         "it.unimi.dsi.fastutil",
+        "javax.annotation",
         "kotlinx.collections.immutable",
         "com.fasterxml",
         "org.codehaus",
