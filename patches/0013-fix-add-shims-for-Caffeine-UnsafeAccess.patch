+package com.android.com.github.benmanes.caffeine.cache;
+
+import com.intellij.util.containers.AndroidUnsafe;
+import org.lsposed.hiddenapibypass.HiddenApiBypass;
+import sun.misc.Unsafe;
+
+import java.lang.reflect.Field;
+import java.util.List;
+
+/**
+ * Static access to {@link Unsafe} and convenient utility methods for performing low-level, unsafe
+ * operations.
+ *
+ * @author ben.manes@gmail.com (Ben Manes)
+ */
+public final class UnsafeAccess {
+
+    public static final Unsafe UNSAFE;
+
+    static {
+        UNSAFE = AndroidUnsafe.getUnsafe();
+    }
+
+    /**
+     * Returns the location of a given static field.
+     *
+     * @param clazz     the class containing the field
+     * @param fieldName the name of the field
+     * @return the address offset of the field
+     */
+    public static long objectFieldOffset(Class<?> clazz, String fieldName) {
+        return AndroidUnsafe.objectFieldOffset(tryGetField(clazz, fieldName));
+    }
+
+
+    private static Field tryGetField(Class<?> clazz, String fieldName) {
+        try {
+            return clazz.getDeclaredField(fieldName);
+        }
+        catch (NoSuchFieldException | SecurityException e) {
+            try {
+                return clazz.getField(fieldName);
+            }
+            catch (NoSuchFieldException | SecurityException e1) {
+                try {
+                    List<Field> staticFields = HiddenApiBypass.getStaticFields(clazz);
+                    List<Field> instanceFields = HiddenApiBypass.getInstanceFields(clazz);
+                    for (Field field : staticFields) {
+                        if (field.getName().equals(fieldName)) {
+                            return field;
+                        }
+                    }
+
+                    for (Field field : instanceFields) {
+                        if (field.getName().equals(fieldName)) {
+                            return field;
+                        }
+                    }
+                }
+                catch (Throwable _e) {
+                    throw new Error(e);
+                }
+            }
+        }
+
+        throw new RuntimeException(fieldName + " not found in " + clazz);
+    }
+
+    private UnsafeAccess() {
+    }
+}
